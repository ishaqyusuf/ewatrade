model RetailOpsCustomer {
  id                   String                      @id @default(cuid())
  tenantId             String
  storeId              String
  customerAccountId    String?
  identityKey          String
  name                 String
  normalizedName       String?
  email                String?
  normalizedEmail      String?
  phone                String?
  normalizedPhone      String?
  firstSeenAt          DateTime                    @default(now())
  lastSeenAt           DateTime                    @default(now())
  orderCount           Int                         @default(0)
  totalMinor           Int                         @default(0)
  lastOrderId          String?
  lastOrderNumber      String?
  createdByUserId      String?
  mergedIntoCustomerId String?
  mergedAt             DateTime?
  metadata             Json?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  tenant               Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store                Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  mergedIntoCustomer   RetailOpsCustomer?          @relation("RetailOpsCustomerMerge", fields: [mergedIntoCustomerId], references: [id], onDelete: SetNull)
  mergedCustomers      RetailOpsCustomer[]         @relation("RetailOpsCustomerMerge")
  identities           RetailOpsCustomerIdentity[]
  events               RetailOpsCustomerEvent[]
  orders               Order[]                     @relation("RetailOpsCustomerOrders")

  @@unique([tenantId, storeId, identityKey])
  @@index([tenantId, storeId, lastSeenAt])
  @@index([customerAccountId, lastSeenAt])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([mergedIntoCustomerId])
}

model RetailOpsCustomerIdentity {
  id              String                        @id @default(cuid())
  tenantId        String
  storeId         String
  customerId      String
  type            RetailOpsCustomerIdentityType
  value           String
  normalizedValue String
  isPrimary       Boolean                       @default(false)
  verifiedAt      DateTime?
  metadata        Json?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  tenant          Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store           Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        RetailOpsCustomer             @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, storeId, type, normalizedValue])
  @@index([customerId, type])
  @@index([tenantId, storeId, isPrimary])
}

model RetailOpsCustomerEvent {
  id          String                     @id @default(cuid())
  tenantId    String
  storeId     String
  customerId  String
  orderId     String?
  actorUserId String?
  type        RetailOpsCustomerEventType
  happenedAt  DateTime                   @default(now())
  metadata    Json?
  createdAt   DateTime                   @default(now())
  tenant      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store       Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer    RetailOpsCustomer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order       Order?                     @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId, storeId, happenedAt])
  @@index([customerId, happenedAt])
  @@index([orderId])
  @@index([actorUserId, happenedAt])
  @@index([type, happenedAt])
}
