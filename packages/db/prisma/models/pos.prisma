model CashierSession {
  id                  String                        @id @default(cuid())
  tenantId            String
  storeId             String
  userId              String
  status              PosSessionStatus              @default(OPEN)
  openedAt            DateTime                      @default(now())
  closedAt            DateTime?
  openingFloatMinor   Int                           @default(0)
  closingFloatMinor   Int?
  notes               String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  store               Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user                User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  receipts            Receipt[]
  barcodeEvents       BarcodeEvent[]
  inventoryMovements  InventoryMovement[]
  retailOpsCloseout   RetailOpsCloseout?
  stockDeclarations   RetailOpsStockDeclaration[]
  paymentDeclarations RetailOpsPaymentDeclaration[]
  closeoutReviews     RetailOpsCloseoutReview[]

  @@index([tenantId, status])
  @@index([storeId, openedAt])
}

model RetailOpsCloseout {
  id                     String                        @id @default(cuid())
  tenantId               String
  storeId                String
  cashierSessionId       String                        @unique
  status                 RetailOpsCloseoutStatus       @default(PENDING_REVIEW)
  expectedTotalMinor     Int                           @default(0)
  declaredTotalMinor     Int                           @default(0)
  varianceTotalMinor     Int                           @default(0)
  paymentVarianceCount   Int                           @default(0)
  stockVarianceLineCount Int                           @default(0)
  submittedByUserId      String?
  submittedAt            DateTime                      @default(now())
  reviewedByUserId       String?
  reviewedAt             DateTime?
  reviewNote             String?
  externalId             String?
  deviceId               String?
  syncEventId            String?
  notes                  String?
  metadata               Json?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  tenant                 Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store                  Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashierSession         CashierSession                @relation(fields: [cashierSessionId], references: [id], onDelete: Cascade)
  stockDeclarations      RetailOpsStockDeclaration[]
  paymentDeclarations    RetailOpsPaymentDeclaration[]
  reviews                RetailOpsCloseoutReview[]

  @@unique([tenantId, storeId, externalId])
  @@index([tenantId, storeId, status])
  @@index([cashierSessionId, status])
  @@index([submittedByUserId, submittedAt])
  @@index([reviewedByUserId, reviewedAt])
}

model RetailOpsPaymentDeclaration {
  id               String                            @id @default(cuid())
  tenantId         String
  storeId          String
  closeoutId       String
  cashierSessionId String
  method           RetailOpsPaymentDeclarationMethod
  expectedMinor    Int                               @default(0)
  declaredMinor    Int                               @default(0)
  varianceMinor    Int                               @default(0)
  declaredByUserId String?
  declaredAt       DateTime                          @default(now())
  note             String?
  metadata         Json?
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  tenant           Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store            Store                             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  closeout         RetailOpsCloseout                 @relation(fields: [closeoutId], references: [id], onDelete: Cascade)
  cashierSession   CashierSession                    @relation(fields: [cashierSessionId], references: [id], onDelete: Cascade)

  @@unique([closeoutId, method])
  @@index([tenantId, storeId, method])
  @@index([cashierSessionId, method])
  @@index([declaredByUserId, declaredAt])
}

model RetailOpsStockDeclaration {
  id               String                          @id @default(cuid())
  tenantId         String
  storeId          String
  closeoutId       String?
  cashierSessionId String
  productId        String
  productVariantId String
  type             RetailOpsStockDeclarationType
  stockSource      RetailOpsStockDeclarationSource @default(CENTRAL_STOCK)
  unitNameSnapshot String
  unitSkuSnapshot  String?
  expectedQuantity Int                             @default(0)
  countedQuantity  Int                             @default(0)
  varianceQuantity Int                             @default(0)
  damagedQuantity  Int                             @default(0)
  lostQuantity     Int                             @default(0)
  declaredByUserId String?
  declaredAt       DateTime                        @default(now())
  note             String?
  metadata         Json?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt
  tenant           Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store            Store                           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  closeout         RetailOpsCloseout?              @relation(fields: [closeoutId], references: [id], onDelete: Cascade)
  cashierSession   CashierSession                  @relation(fields: [cashierSessionId], references: [id], onDelete: Cascade)
  product          Product                         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariant   ProductVariant                  @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([cashierSessionId, type, productVariantId, stockSource])
  @@index([tenantId, storeId, type])
  @@index([closeoutId])
  @@index([productVariantId, declaredAt])
  @@index([declaredByUserId, declaredAt])
}

model RetailOpsCloseoutReview {
  id               String                        @id @default(cuid())
  tenantId         String
  storeId          String
  closeoutId       String
  cashierSessionId String
  result           RetailOpsCloseoutReviewResult
  reviewedByUserId String
  reviewedAt       DateTime                      @default(now())
  note             String?
  metadata         Json?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  tenant           Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store            Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  closeout         RetailOpsCloseout             @relation(fields: [closeoutId], references: [id], onDelete: Cascade)
  cashierSession   CashierSession                @relation(fields: [cashierSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, storeId, reviewedAt])
  @@index([closeoutId, reviewedAt])
  @@index([cashierSessionId, reviewedAt])
  @@index([reviewedByUserId, reviewedAt])
  @@index([result, reviewedAt])
}

model Receipt {
  id               String          @id @default(cuid())
  tenantId         String
  storeId          String
  orderId          String?
  cashierSessionId String?
  issuedByUserId   String?
  receiptNumber    String
  subtotalMinor    Int             @default(0)
  taxMinor         Int             @default(0)
  totalMinor       Int             @default(0)
  paymentMethod    String?
  issuedAt         DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  store            Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order            Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  cashierSession   CashierSession? @relation(fields: [cashierSessionId], references: [id], onDelete: SetNull)
  issuedBy         User?           @relation(fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@unique([storeId, receiptNumber])
  @@index([tenantId, issuedAt])
}

model BarcodeEvent {
  id               String          @id @default(cuid())
  tenantId         String
  storeId          String
  cashierSessionId String?
  userId           String?
  code             String
  payload          String?
  happenedAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())
  cashierSession   CashierSession? @relation(fields: [cashierSessionId], references: [id], onDelete: SetNull)
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, happenedAt])
  @@index([storeId, code])
}
