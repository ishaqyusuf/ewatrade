model OfflineDevice {
  id                 String                    @id @default(cuid())
  tenantId           String
  storeId            String?
  deviceId           String
  deviceName         String?
  platform           OfflineDevicePlatform     @default(UNKNOWN)
  appVersion         String?
  status             OfflineDeviceStatus       @default(ACTIVE)
  registeredByUserId String?
  registeredAt       DateTime                  @default(now())
  lastSeenAt         DateTime                  @default(now())
  revokedAt          DateTime?
  revokedByUserId    String?
  metadata           Json?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store              Store?                    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  revocations        OfflineDeviceRevocation[]
  commands           OfflineCommand[]

  @@unique([tenantId, deviceId])
  @@index([tenantId, status])
  @@index([storeId, lastSeenAt])
}

model OfflineCommand {
  id                  String                  @id @default(cuid())
  tenantId            String
  storeId             String
  offlineDeviceId     String
  clientCommandId     String
  type                OfflineCommandType
  status              OfflineCommandStatus    @default(PENDING)
  eventVersion        Int                     @default(1)
  payloadHash         String
  dependencyClientIds Json
  payload             Json
  result              Json?
  conflictCode        OfflineConflictCode?
  conflictMessage     String?
  attemptedState      Json?
  authoritativeState  Json?
  createdAtClient     DateTime
  processedAt         DateTime?
  reviewedAt          DateTime?
  reviewedByUserId    String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store               Store                   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  offlineDevice       OfflineDevice           @relation(fields: [offlineDeviceId], references: [id], onDelete: Restrict)
  reviews             OfflineConflictReview[]

  @@unique([tenantId, clientCommandId])
  @@index([tenantId, status, createdAtClient])
  @@index([storeId, status, createdAtClient])
  @@index([offlineDeviceId, createdAtClient])
}

model OfflineConflictReview {
  id                 String                @id @default(cuid())
  commandId          String
  decision           OfflineReviewDecision
  reason             String?
  dependentClientIds Json
  reviewedByUserId   String
  createdAt          DateTime              @default(now())
  command            OfflineCommand        @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@index([commandId, createdAt])
  @@index([reviewedByUserId, createdAt])
}

model OfflineDeviceRevocation {
  id               String                @id @default(cuid())
  tenantId         String
  offlineDeviceId  String?
  deviceId         String
  deviceName       String?
  platform         OfflineDevicePlatform @default(UNKNOWN)
  appVersion       String?
  revokedByUserId  String
  revokedAt        DateTime              @default(now())
  restoredByUserId String?
  restoredAt       DateTime?
  reason           String?
  metadata         Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offlineDevice    OfflineDevice?        @relation(fields: [offlineDeviceId], references: [id], onDelete: SetNull)

  @@index([tenantId, deviceId])
  @@index([tenantId, revokedAt])
  @@index([offlineDeviceId, revokedAt])
}
