model Store {
  id                          String                      @id @default(cuid())
  tenantId                    String
  slug                        String
  name                        String
  description                 String?
  status                      StoreStatus                 @default(DRAFT)
  currencyCode                String                      @default("NGN")
  supportPhone                String?
  supportEmail                String?
  addressLine1                String?
  addressLine2                String?
  city                        String?
  region                      String?
  postalCode                  String?
  countryCode                 String?
  isMarketplaceLive           Boolean                     @default(false)
  metadata                    Json?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  tenant                      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  retailOpsStaffProfiles      RetailOpsStaffProfile[]
  pages                       Page[]
  sites                       Site[]
  themes                      Theme[]
  templates                   Template[]
  offlineDevices              OfflineDevice[]
  offlineCommands             OfflineCommand[]
  serviceIntakes              ServiceIntake[]
  serviceJobs                 ServiceJob[]
  serviceRequestForms         ServiceRequestForm[]
  serviceRequests             ServiceRequest[]
  serviceQuotes               ServiceQuote[]
  serviceNotificationIntents  ServiceNotificationIntent[]
  serviceSettings             ServiceStoreSettings?
  catalogOfferingAvailability StoreOfferingAvailability[]
  catalogCommandReceipts      CatalogCommandReceipt[]
  stockBalanceSources         StockBalanceSource[]
  stockOperations             StockOperation[]
  stockReservations           StockReservation[]
  stockCounts                 StockCount[]
  outboundStockTransfers      StockTransfer[]             @relation("StockTransferSourceStore")
  inboundStockTransfers       StockTransfer[]             @relation("StockTransferTargetStore")
  inventoryCloseouts          InventoryCloseout[]
  commercialOrders            CommercialOrder[]
  commercialOrderPayments     CommercialOrderPayment[]
  productReturns              ProductReturn[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}
