model Tenant {
  id                            String                         @id @default(cuid())
  slug                          String                         @unique
  name                          String
  type                          TenantType
  enabledModes                  TenantMode[]
  isActive                      Boolean                        @default(true)
  timezone                      String                         @default("Africa/Lagos")
  countryCode                   String?
  currencyCode                  String                         @default("NGN")
  metadata                      Json?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  users                         Membership[]
  stores                        Store[]
  sites                         Site[]
  hostnames                     TenantHostname[]
  conversations                 Conversation[]
  automations                   AutomationEvent[]
  subscription                  TenantSubscription?
  billingCheckoutSessions       BillingCheckoutSession[]
  billingInvoices               BillingInvoice[]
  billingProviderEvents         BillingProviderEvent[]
  retailOpsStaffProfiles        RetailOpsStaffProfile[]
  retailOpsStaffInviteTokens    RetailOpsStaffInviteToken[]
  retailOpsStaffLifecycleEvents RetailOpsStaffLifecycleEvent[]
  offlineDevices                OfflineDevice[]
  offlineDeviceRevocations      OfflineDeviceRevocation[]
  serviceIntakes                ServiceIntake[]
  serviceJobs                   ServiceJob[]
  serviceWorkEvents             ServiceWorkEvent[]
  serviceEvidence               ServiceEvidence[]
  serviceRequestForms           ServiceRequestForm[]
  serviceRequests               ServiceRequest[]
  serviceQuotes                 ServiceQuote[]
  customerTrackingAccess        CustomerTrackingAccess[]
  serviceNotificationIntents    ServiceNotificationIntent[]
  serviceStoreSettings          ServiceStoreSettings[]
  catalogItems                  CatalogItem[]
  catalogUnitDefinitions        UnitDefinition[]
  catalogOfferings              SellableOffering[]
  catalogProductUnitOfferings   ProductUnitOffering[]
  catalogPriceChanges           CatalogPriceChange[]
  catalogCommandReceipts        CatalogCommandReceipt[]
  stockBalanceSources           StockBalanceSource[]
  stockOperations               StockOperation[]
  stockReservations             StockReservation[]
  stockCounts                   StockCount[]
  stockTransfers                StockTransfer[]
  inventoryCloseouts            InventoryCloseout[]
  commercialOrders              CommercialOrder[]
  commercialOrderPayments       CommercialOrderPayment[]
  productReturns                ProductReturn[]
  offlineCommands               OfflineCommand[]
}

model TenantHostname {
  id         String                @id @default(cuid())
  tenantId   String
  surface    TenantHostnameSurface
  hostname   String                @unique
  isPrimary  Boolean               @default(false)
  isCustom   Boolean               @default(false)
  verifiedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, surface, hostname])
  @@index([tenantId, surface])
}

model OnboardingSession {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  tenantId  String?
  userId    String?
  step      Int      @default(1)
  formData  Json?
  completed Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([tenantId])
}

model LeadCapture {
  id          String          @id @default(cuid())
  type        LeadCaptureType
  email       String
  fullName    String
  companyName String?
  roleTitle   String?
  phone       String?
  message     String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([type, createdAt])
  @@index([email, createdAt])
}

model User {
  id                     String                  @id @default(cuid())
  name                   String                  @default("")
  email                  String                  @unique
  emailVerified          Boolean                 @default(false)
  emailVerifiedAt        DateTime?
  image                  String?
  phone                  String?                 @unique
  firstName              String?
  lastName               String?
  displayName            String?
  avatarUrl              String?
  isPlatformAdmin        Boolean                 @default(false)
  metadata               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  sessions               Session[]
  memberships            Membership[]
  retailOpsStaffProfiles RetailOpsStaffProfile[] @relation("RetailOpsStaffProfileUser")
  sentMessages           Message[]
  automationEvents       AutomationEvent[]       @relation("AutomationActor")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  provider              String?
  providerAccountId     String?
  accessToken           String?
  refreshToken          String?
  expiresAt             DateTime?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenType             String?
  scope                 String?
  idToken               String?
  password              String?
  passwordHash          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Membership {
  id                            String                         @id @default(cuid())
  tenantId                      String
  userId                        String
  role                          MembershipRole
  status                        MembershipStatus               @default(ACTIVE)
  invitedById                   String?
  invitedAt                     DateTime?
  acceptedAt                    DateTime?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  tenant                        Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                          User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  retailOpsStaffProfile         RetailOpsStaffProfile?
  retailOpsStaffInviteTokens    RetailOpsStaffInviteToken[]
  retailOpsStaffLifecycleEvents RetailOpsStaffLifecycleEvent[]

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@index([userId, status])
}
