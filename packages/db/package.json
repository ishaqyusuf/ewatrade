{
  "name": "@ewatrade/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": ["src", "generated", "prisma", "prisma.config.ts"],
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./queries": "./src/queries/index.ts",
    "./enums": "./generated/prisma/enums.ts",
    "./browser": "./generated/prisma/browser.ts"
  },
  "scripts": {
    "build": "bun run db:generate && tsc --noEmit",
    "generate": "bun run db:generate",
    "format": "bun run db:format",
    "migrate:dev": "bun run db:migrate",
    "migrate:deploy": "bun run db:migrate:deploy",
    "migrate:legacy-services": "bun scripts/migrate-legacy-service-operations.ts",
    "db:push": "prisma db push",
    "seed:retail-ops-reference": "bun scripts/seed-retail-ops-reference-data.ts",
    "validate:retail-ops-live": "bun scripts/retail-ops-live-validation.ts",
    "validate:retail-ops-full": "bun scripts/run-retail-ops-full-validation.ts",
    "validate:retail-ops-workflows": "bun scripts/validate-retail-ops-workflows.ts",
    "studio": "bun run db:studio",
    "lint": "biome check .",
    "typecheck": "bun run db:generate && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:format": "prisma format",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@ewatrade/utils": "workspace:*",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@ewatrade/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "dotenv": "^17.2.3",
    "prisma": "^7.0.0",
    "typescript": "catalog:"
  }
}
