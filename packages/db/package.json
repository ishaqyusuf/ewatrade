{
  "name": "@ewatrade/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": [
    "src",
    "prisma",
    "prisma.config.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./queries": "./src/queries/index.ts",
    "./enums": "./src/generated/prisma/enums.ts",
    "./browser": "./src/generated/prisma/browser.ts"
  },
  "scripts": {
    "build": "bun run generate && tsc --noEmit",
    "generate": "node node_modules/prisma/build/index.js generate --config prisma.config.ts",
    "format": "node node_modules/prisma/build/index.js format --config prisma.config.ts",
    "migrate:dev": "node node_modules/prisma/build/index.js migrate dev --config prisma.config.ts",
    "migrate:deploy": "node node_modules/prisma/build/index.js migrate deploy --config prisma.config.ts",
    "db:push": "node node_modules/prisma/build/index.js db push --config prisma.config.ts",
    "seed:retail-ops-reference": "bun scripts/seed-retail-ops-reference-data.ts",
    "validate:retail-ops-live": "bun scripts/retail-ops-live-validation.ts",
    "validate:retail-ops-full": "bun scripts/run-retail-ops-full-validation.ts",
    "validate:retail-ops-workflows": "bun scripts/validate-retail-ops-workflows.ts",
    "studio": "node node_modules/prisma/build/index.js studio --config prisma.config.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@ewatrade/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "dotenv": "^17.2.3",
    "prisma": "^7.0.0",
    "typescript": "catalog:"
  }
}
