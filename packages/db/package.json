{
  "name": "@ewatrade/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": [
    "src",
    "prisma",
    "prisma.config.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./enums": "./src/generated/prisma/enums.ts",
    "./browser": "./src/generated/prisma/browser.ts"
  },
  "scripts": {
    "generate": "prisma generate --config prisma.config.ts",
    "format": "prisma format --config prisma.config.ts",
    "migrate:dev": "prisma migrate dev --config prisma.config.ts",
    "migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "studio": "prisma studio --config prisma.config.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@ewatrade/tsconfig": "workspace:*",
    "dotenv": "^17.2.3",
    "prisma": "^7.0.0",
    "typescript": "^5.9.3"
  }
}
