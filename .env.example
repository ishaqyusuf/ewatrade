# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:55436/ewatrade
REMOTE_DEV_DATABASE_URL=
PROD_DATABASE_URL=
DB_HOST=localhost
DB_HOST_PORT=55436
DB_NAME=ewatrade
DB_USER=postgres
DB_PASSWORD=postgres

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@ewatrade.local
EMAIL_REPLY_TO=team@ewatrade.local
MARKETING_INBOX_EMAILS=team@ewatrade.local
RESEND_API_KEY=
# Comma-separated primary recipients for exact @test.com email routing.
TEST_EMAILS=
# Legacy single-recipient fallback when TEST_EMAILS is empty.
TEST_EMAIL=

# ── Trigger.dev Jobs ─────────────────────────────────────────────────────────
TRIGGER_PROJECT_ID=
TRIGGER_PROFILE=ishaqyusuf
TRIGGER_SECRET_KEY=

# ── Runtime URLs ──────────────────────────────────────────────────────────────
API_URL=http://localhost:3095
NEXT_PUBLIC_API_URL=http://localhost:3095
STOREFRONT_URL=http://localhost:3092
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3092
NEXT_PUBLIC_APP_URL=http://localhost:3092
MOBILE_APP_URL=http://localhost:3096
NEXT_PUBLIC_MARKETING_URL=http://localhost:3092
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3094
PLATFORM_DOMAIN=localhost:3092
NEXT_PUBLIC_PLATFORM_DOMAIN=localhost:3092
ALLOWED_API_ORIGINS=http://localhost:3092,http://localhost:3094,http://localhost:3095
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3092,http://localhost:3094,http://localhost:3095

# ── Local Dev Ports ──────────────────────────────────────────────────────────
LEGACY_MOBILE_PORT=3002
STOREFRONT_PORT=3091
MARKETING_PORT=3092
POS_PORT=3093
DASHBOARD_PORT=3094
API_PORT=3095
EXPO_PORT=3096

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Server-side allowed audiences for Google ID token verification.
GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Expo client IDs used to launch Google sign-in from the mobile app.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Optional guarded live Google OAuth QA.
# This verifies a fresh Google ID token through the deployed API and may create
# or update account/session records, so keep confirmation blank unless approved.
# The evidence path is required so the run leaves a value-safe JSON proof file.
GOOGLE_LIVE_CONFIRM_AUTH=
GOOGLE_LIVE_ID_TOKEN=
GOOGLE_LIVE_MODE=
GOOGLE_LIVE_EXPECTED_EMAIL=
GOOGLE_LIVE_EVIDENCE_PATH=
GOOGLE_LIVE_NAME=
GOOGLE_LIVE_BUSINESS_NAME=
GOOGLE_LIVE_ALLOW_LOCALHOST=

# ── Mobile Retail Ops Live Shared-Link QA ────────────────────────────────────
# Set the confirmations only for an intentional live shared-link QA run that may
# create product links, customer order requests, notification audit rows, and
# follow-up records against the selected API/storefront/database target.
# The evidence path is required so the run leaves a value-safe JSON proof file.
SHARED_LINK_LIVE_CONFIRM_WRITES=
SHARED_LINK_LIVE_CONFIRM_EMAIL_DELIVERY=
SHARED_LINK_LIVE_OWNER_BEARER_TOKEN=
SHARED_LINK_LIVE_PRODUCT_ID=
SHARED_LINK_LIVE_CUSTOMER_EMAIL=
SHARED_LINK_LIVE_CUSTOMER_NAME=
SHARED_LINK_LIVE_CUSTOMER_PASSWORD=
SHARED_LINK_LIVE_FOLLOW_UP_MODE=
SHARED_LINK_LIVE_EVIDENCE_PATH=
# Optional. Defaults to 1 when blank.
SHARED_LINK_LIVE_QUANTITY=
SHARED_LINK_LIVE_ALLOW_LOCALHOST=

# Optional non-mutating public preview check for an existing deployed share URL.
# Use this before release to verify canonical, Open Graph, Twitter, and OG image
# responses from the exact URL that will be pasted into WhatsApp or similar apps.
SHARED_LINK_PREVIEW_URL=
SHARED_LINK_PREVIEW_EXPECTED_HOST=
SHARED_LINK_PREVIEW_EXPECTED_PRODUCT_NAME=
SHARED_LINK_PREVIEW_EXPECTED_BUSINESS_NAME=
SHARED_LINK_PREVIEW_EVIDENCE_PATH=
SHARED_LINK_PREVIEW_ALLOW_LOCALHOST=

# Optional guarded browser checkout smoke for an existing deployed share URL.
# This submits a disposable customer order request, so keep the confirmation
# blank unless the selected product link is approved for browser checkout QA.
# The screenshot path is required so the run leaves durable browser evidence.
SHARED_LINK_BROWSER_CONFIRM_ORDER=
SHARED_LINK_BROWSER_CUSTOMER_EMAIL=
SHARED_LINK_BROWSER_CUSTOMER_NAME=
SHARED_LINK_BROWSER_CUSTOMER_PASSWORD=
SHARED_LINK_BROWSER_AUTH_MODE=
# Optional. Defaults to 1 when blank.
SHARED_LINK_BROWSER_QUANTITY=
SHARED_LINK_BROWSER_CUSTOMER_PHONE=
SHARED_LINK_BROWSER_NOTES=
SHARED_LINK_BROWSER_SCREENSHOT_PATH=
SHARED_LINK_BROWSER_HEADFUL=
SHARED_LINK_BROWSER_ALLOW_LOCALHOST=

# ── Signup Feature Flag ──────────────────────────────────────────────────────
# Set to "true" to show signup CTAs and enable /signup route.
# Keep false in production until launch-ready.
NEXT_PUBLIC_SIGNUP_ENABLED=false
# Early-access signup links are one-time onboarding sessions. Defaults to 7 days.
EARLY_ACCESS_LINK_TTL_DAYS=7

# ── Vercel Domain Management ──────────────────────────────────────────────────
# Required to auto-provision tenant storefront subdomains on signup.
# POS and dashboard project IDs are optional until those Vercel projects exist.
VERCEL_API_TOKEN=
VERCEL_STOREFRONT_PROJECT_ID=
VERCEL_POS_PROJECT_ID=
VERCEL_DASHBOARD_PROJECT_ID=
