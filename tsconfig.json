{
  "extends": "./packages/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@api/*": [
        "apps/api/src/*"
      ]
    }
  },
  "include": [
    "apps/api/src/**/*.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "apps/dashboard",
    "apps/marketing",
    "apps/pos",
    "apps/storefront"
  ]
}