{
  "name": "ewatrade",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "dev": "turbo dev --parallel",
    "dev:web": "turbo dev --filter=@ewatrade/web",
    "db:generate": "bun run --cwd packages/db generate",
    "db:format": "bun run --cwd packages/db format",
    "db:migrate:dev": "bun run --cwd packages/db migrate:dev",
    "db:migrate:deploy": "bun run --cwd packages/db migrate:deploy",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
