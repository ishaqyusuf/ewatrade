{
  "name": "@ewatrade/storefront",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/with-workspace-env.mjs PORTLESS_WILDCARD=1 PORTLESS_HTTPS=0 PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-3091} TZ=UTC portless ewatrade-storefront next dev --turbopack",
    "dev:portless": "node ../../scripts/with-workspace-env.mjs PORTLESS_WILDCARD=1 PORTLESS_HTTPS=0 portless ewatrade-storefront next dev --turbopack",
    "build": "bun next build --turbopack",
    "start": "next start",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ewatrade/auth": "workspace:*",
    "@ewatrade/db": "workspace:*",
    "@ewatrade/jobs": "workspace:*",
    "@ewatrade/ui": "workspace:*",
    "@ewatrade/utils": "workspace:*",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@ewatrade/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@biomejs/biome": "^1.9.4",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
