# apps/mobile env example
# Local env uses .env.local; production uses .env.production; examples use .env.example.

## PROJECT
APP_VARIANT=development
EXPO_PUBLIC_APP_VARIANT=development
EXPO_PUBLIC_BASE_URL=http://localhost:3092

## API
EXPO_PUBLIC_API_URL=http://localhost:3095
EXPO_PUBLIC_API_PORT=3095

## WEB LINKS
EXPO_PUBLIC_WEB_URL=
EXPO_PUBLIC_WEB_PORT=3092

## GOOGLE OAUTH
GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

## DEV SERVER
EWATRADE_EXPO_PORT=3002
