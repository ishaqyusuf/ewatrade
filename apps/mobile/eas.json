{
	"cli": {
		"version": ">= 16.9.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"APP_VARIANT": "development",
				"SKIP_OTP": "1"
			}
		},
		"preview": {
			"distribution": "internal",
			"env": {
				"APP_VARIANT": "preview"
			},
			"autoIncrement": true,
			"channel": "preview"
		},
		"production": {
			"autoIncrement": true,
			"env": {
				"SKIP_OTP": "0"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
